TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# LLM Providers: openrouter, groq, ollama, local
LLM_PROVIDER=local
# For local provider, use the HF_MODEL_TEXT or similar
LLM_MODEL=

# Local Inference (vLLM)
VLLM_GPU_UTILIZATION=0.7
#HF_MODEL_TEXT=Qwen/Qwen2.5-3B-Instruct-AWQ
HF_MODEL_TEXT=Qwen/Qwen2.5-Coder-7B-Instruct
HF_MODEL_MEDIA=HuggingFaceTB/SmolVLM2-2.2B-Instruct
MAX_CONTEXT_LEN=8192

# Database
DB_PATH=summagram.db
CHROMA_DB_PATH=./chroma_data

# App
DISCOVERY_DAYS=90
